---
const linkNav = [
  {name: 'sobre nosotros', link: '#sobre-nosotros'},
  {name: 'proyectos', link: '#proyectos'},
  {name: 'servicios', link: '#servicios'},
  {name: 'stack',  link: '#stack'}
]
---

<nav
  class="border-b border-(--hairline) h-14 w-full fixed flex lg:flex items-center justify-between px-4 lg:px-8 bg-(--floor) z-50"
  aria-label="Navegación principal"
>
  <a href="#top" class="focus:outline-none focus:ring-2 focus:ring-(--gold) focus:ring-offset-2 focus:ring-offset-(--floor)" aria-label="Ir al inicio de AXVOL">
    <p class="font-serif md:text-2xl lg:text-4xl tracking-[10%] text-nowrap">
      AXVOL <span class="text-(--gold)">.</span>
    </p>
  </a>

  <div class="hidden lg:flex w-1/2 items-center justify-around">
    
    {
      linkNav.map((link, i) => (
        <a href={link.link} class="font-sans text-sm lg:text-base text-(--text-muted) hover:text-(--gold) uppercase">{link.name}</a>
      ))
    }
  </div>

  <a
    href="#contacto"
    class="hidden lg:inline-flex border border-(--hairline) hover:border-(--gold) hover:text-(--gold) px-2 py-1 text-sm lg:text-base text-nowrap cursor-pointer"
    >INICIAR PROYECTO</a
  >

  <button
    id="hamburgerButton"
    class="flex lg:hidden flex-col justify-between h-4 w-5 focus:outline-none"
    aria-label="Abrir menú"
    aria-controls="mobileSidebar"
    aria-expanded="false"
    type="button"
  >
    <span class="block h-0.5 w-full bg-(--text-muted) transition-all duration-300"></span>
    <span class="block h-0.5 w-full bg-(--text-muted) transition-all duration-300"></span>
    <span class="block h-0.5 w-full bg-(--text-muted) transition-all duration-300"></span>
  </button>
</nav>

<div
  id="mobileOverlay"
  class="fixed inset-0 bg-black/30 opacity-0 pointer-events-none transition-opacity duration-300 ease-in-out z-40"
></div>

<aside
  id="mobileSidebar"
  class="fixed top-0 right-0 h-full w-11/12 max-w-xs bg-(--panel) shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out z-50"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  <div class="flex items-center justify-between p-4 border-b border-(--hairline)">
    <p class="font-sans text-lg text-(--text-muted)">MENÚ</p>
    <button
      id="closeButton"
      class="text-(--text-muted) hover:text-(--gold) text-4xl leading-none"
      aria-label="Cerrar menú"
      type="button"
    >
      &times;
    </button>
  </div>
  <nav class="flex flex-col gap-4 p-4">
  {
    linkNav.map((link,i) => (
      <a href={link.link} class="font-sans text-base text-(--text-muted) uppercase">{link.name}</a>
    ))
  }
  </nav>
</aside>

<script>
  const sidebar = typeof document !== 'undefined' ? document.getElementById('mobileSidebar') : null;
  const overlay = typeof document !== 'undefined' ? document.getElementById('mobileOverlay') : null;
  const openButton = typeof document !== 'undefined' ? document.getElementById('hamburgerButton') : null;
  const closeButton = typeof document !== 'undefined' ? document.getElementById('closeButton') : null;

  function toggleMenu(open) {
    if (!sidebar || !overlay || !openButton) return;
    if (open) {
      sidebar.classList.remove('translate-x-full');
      sidebar.classList.add('translate-x-0');
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      sidebar.setAttribute('aria-hidden', 'false');
      openButton.setAttribute('aria-expanded', 'true');
    } else {
      sidebar.classList.remove('translate-x-0');
      sidebar.classList.add('translate-x-full');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100');
      sidebar.setAttribute('aria-hidden', 'true');
      openButton.setAttribute('aria-expanded', 'false');
    }
  }

  if (openButton) {
    openButton.addEventListener('click', () => toggleMenu(true));
  }

  if (closeButton) {
    closeButton.addEventListener('click', () => toggleMenu(false));
  }

  if (overlay) {
    overlay.addEventListener('click', () => toggleMenu(false));
  }

  if (sidebar) {
    const links = sidebar.querySelectorAll('a');
    links.forEach((link) => {
      link.addEventListener('click', () => toggleMenu(false));
    });
  }
</script>
