---
---

<section
  class="h-dvh flex flex-col justify-center items-center gap-2.5 border-b border-(--hairline)"
  id="contacto"
>
  <div class="w-4/5 flex flex-col lg:flex-row">
    <div class="w-full lg:w-1/2">
      <p class="text-(--gold)">CONTACTO</p>
      <h2 class="text-4xl">TRABAJEMOS JUNTOS</h2>
      <p class="text-(--text-muted) my-2 lg:mt-2 md:w-100 font-mono">
        Cuéntanos qué producto tienes en mente. Respondemos en menos de 24 horas
        con una fecha para verlo en sala.
      </p>
    </div>
    <div class="w-full lg:w-1/2">
      <form action="https://api.web3forms.com/submit" method="post">
        <input
          type="hidden"
          name="access_key"
          value="c610f918-6dc9-4759-ba05-58823c4536dc"
        />
         <input type="hidden" name="from_name" value="AXVOL Estudio">
        <!-- IMPORTANTE: Web3Forms lee este campo para saber a quién responder -->
        <input type="hidden" name="redirect" value="http://localhost:4321/" />
        <div class="flex flex-col lg:px-4">
          <label for="nombre">Nombre</label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            class="border-b border-(--hairline) hover:border-(--gold) focus:border-(--gold) pl-2 outline-0"
          />
        </div>
        <div class="flex flex-col lg:px-4">
          <label for="email">Correo</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="border-b border-(--hairline) hover:border-(--gold) focus:border-(--gold) pl-2 outline-0"
          />
        </div>
        <div class="flex flex-col lg:px-4">
          <label for="message">Cuéntanos sobre tu proyecto</label>
          <textarea
            name="message"
            id="message"
            cols="20"
            rows="5"
            minlength="20"
            class="border border-(--hairline) hover:border-(--gold) focus:border-(--gold) pl-2 outline-0"
          ></textarea>
        </div>
        <button
          type="submit"
          class="px-5 py-2.5 bg-(--gold) text-(--floor) hover:bg-(--gold-dim) cursor-pointer mt-[5%] mx-4"
          >ENVIAR</button
        >
      </form>
    </div>
    <div id="result"></div>
  </div>
</section>

<script src="../layouts/app.js"></script>